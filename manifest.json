{
  "manifest_version": 3,
  "name": "크롬 팻",
  "version": "0.1.0",
  "description": "브라우저 속에서 키우는 팻 확장",
  "permissions": ["storage", "alarms", "sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "팻 열기"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pet.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
