{
  "name": "chrome-pet",
  "version": "0.1.0",
  "description": "크롬 팻 확장 (Manifest V3) — 하네스 기반 개발",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate": "node scripts/validate-manifest.mjs",
    "build": "node scripts/build.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run validate && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.5",
    "@types/pngjs": "^6.0.5",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  }
}
